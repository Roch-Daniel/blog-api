{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],

    "rootDir": ".",
    "outDir": "./dist",

    "esModuleInterop": true,
    "resolveJsonModule": true,

    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "types": ["node", "jest"],

    "sourceMap": true,
    "declaration": false,

    "incremental": true
  },

  "include": ["src/**/*.ts", "tests/**/*.ts", "**/*.test.ts", "**/*.spec.ts"],

  "exclude": ["node_modules", "dist"]
}
